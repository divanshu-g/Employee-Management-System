generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_id            Int          @id @default(autoincrement())
  email              String       @unique
  password_hash      String
  is_active          Boolean      @default(true)
  last_login         DateTime?
  created_at         DateTime     @default(now())
  updated_at         DateTime     @default(now()) @updatedAt

  departmentsCreated Department[] @relation("CreatedByUser")
  departmentsUpdated Department[]  @relation("UpdatedByUser")

  employeesCreated   Employee[]   @relation("CreatedBy")
  employeesUpdated   Employee[]   @relation("UpdatedBy")
  employees          Employee[]
   
  assignedUserRoles  UserRole[]   @relation("AssignedBy")
  user_roles         UserRole[]

  weeklyTimesheets   WeeklyTimesheet[] @relation("TimesheetUser")
  approvedTimesheets WeeklyTimesheet[] @relation("TimesheetApprovedBy") 


  leaves             Leave[]                 @relation("LeaveUser")
  approvedLeaves     Leave[]                 @relation("LeaveApprovedBy")
}

model Role {
  role_id          Int        @id @default(autoincrement())
  role_name        String     @unique
  role_type        RoleType
  role_description String?
  permissions      Json?
  is_active        Boolean    @default(true)
  created_at       DateTime   @default(now())
  user_roles       UserRole[]
}

model UserRole {
  user_role_id   Int      @id @default(autoincrement())
  user_id        Int
  role_id        Int
  assigned_at    DateTime @default(now())
  assigned_by_id Int?
  is_active      Boolean  @default(true)
  assigned_by    User?    @relation("AssignedBy", fields: [assigned_by_id], references: [user_id])
  role           Role     @relation(fields: [role_id], references: [role_id])
  user           User     @relation(fields: [user_id], references: [user_id])
  @@unique([user_id,role_id])
}

model Department {
  department_id        Int          @id @default(autoincrement())
  department_name      String
  department_code      String       @unique
  description          String?
  parent_department_id Int?
  created_at           DateTime     @default(now())
  updated_at           DateTime     @default(now()) @updatedAt
  is_active            Boolean      @default(true)
  created_by_id        Int
  updated_by_id        Int?
  department_head_id   Int?
  created_by           User         @relation("CreatedByUser", fields: [created_by_id], references: [user_id])
  updated_by           User?        @relation("UpdatedByUser", fields: [updated_by_id], references: [user_id])
  department_head      Employee?    @relation("DepartmentHead", fields: [department_head_id], references: [emp_id])
  parent_department    Department?  @relation("ParentDepartment", fields: [parent_department_id], references: [department_id])
  children             Department[] @relation("ParentDepartment")
  employees            Employee[]   @relation("DepartmentEmployees")
  positions            Position[]
}

model Position {
  position_id      Int        @id @default(autoincrement())
  position_title   String
  position_code    String     @unique
  job_description  String?
  required_skills  Json?
  salary           Float?
  position_level   Int?
  is_active        Boolean    @default(true)
  department_id    Int
  created_at       DateTime     @default(now())  
  updated_at       DateTime     @default(now()) @updatedAt
  employees        Employee[]
  department       Department @relation(fields: [department_id], references: [department_id])
}

model Employee {
  emp_id                Int               @id @default(autoincrement())
  user_id               Int?
  employee_code         String            @unique
  first_name            String
  last_name             String
  personal_email        String?           
  phone_number          String?
  emergency_contact     Json?
  date_of_birth         DateTime?
  gender                Gender?
  address               Json?
  department_id         Int?
  position_id           Int?
  employment_type       EmploymentType?
  work_location         WorkLocation?
  hire_date             DateTime
  probation_end_date    DateTime?
  confirmation_date     DateTime?
  termination_date      DateTime?
  direct_manager_id     Int?
  skip_level_manager_id Int?
  employment_status     EmploymentStatus? @default(Active)
  is_people_manager     Boolean           @default(false)
  created_at            DateTime          @default(now())
  created_by_id         Int?
  updated_at            DateTime          @default(now()) @updatedAt
  updated_by_id         Int?
  heads_departments     Department[]      @relation("DepartmentHead")
  created_by            User?             @relation("CreatedBy", fields: [created_by_id], references: [user_id])
  department            Department?       @relation("DepartmentEmployees", fields: [department_id], references: [department_id])
  direct_manager        Employee?         @relation("DirectManager", fields: [direct_manager_id], references: [emp_id])
  manages_direct        Employee[]        @relation("DirectManager")
  position              Position?         @relation(fields: [position_id], references: [position_id])
  skip_level_manager    Employee?         @relation("SkipLevelManager", fields: [skip_level_manager_id], references: [emp_id])
  manages_skip          Employee[]        @relation("SkipLevelManager")
  updated_by            User?             @relation("UpdatedBy", fields: [updated_by_id], references: [user_id])
  user                  User?             @relation(fields: [user_id], references: [user_id])
}

/* ========== Timesheet / Leave (Employee-anchored) ========== */


model WeeklyTimesheet {
  weekly_timesheet_id Int              @id @default(autoincrement())
  user_id             Int
  week_start          DateTime         // Always Monday
  status              TimesheetStatus  @default(Open)
  created_at          DateTime         @default(now())
  updated_at          DateTime         @default(now()) @updatedAt

  // Manager approval workflow
  submitted_at    DateTime?          // Employee submitted
  approved_at     DateTime?          // Manager approved whole week
  approved_by     Int?               // Manager's user_id

  // Relations
  user     User  @relation("TimesheetUser", fields: [user_id], references: [user_id])
  approver User? @relation("TimesheetApprovedBy", fields: [approved_by], references: [user_id])

  days    TimesheetDay[]

  @@unique([user_id, week_start])
}

model TimesheetDay {
  timesheetday_id      Int               @id @default(autoincrement())
  weekly_timesheet_id  Int 
  leave_id             Int?
  date                 DateTime          // Mon..Sun
  check_in             DateTime?
  check_out            DateTime?
  duration             Float?            // hours
  summary              String?

  // Statuses
  status          TimesheetDayStatus @default(Pending)

  // Audit
  created_by Int?
  updated_by Int?

  // Relations
  weekly_timesheet WeeklyTimesheet @relation(fields: [weekly_timesheet_id], references: [weekly_timesheet_id])
  leave           Leave?           @relation(fields: [leave_id], references: [leave_id])

  @@unique([weekly_timesheet_id, date])
}

model Leave {
  leave_id    Int        @id @default(autoincrement())
  user_id     Int
  start_date  DateTime
  end_date    DateTime
  leaveType   LeaveType
  reason      String?
  leave_duration Float?             // 0.5 = half day, 1 = full day

  status      ApprovalStatus   @default(Pending)  // approval flow
  applied_at  DateTime         @default(now())
  approved_at DateTime?
  approved_by Int?

  // Relations
  user     User  @relation("LeaveUser", fields: [user_id], references: [user_id])
  approver User? @relation("LeaveApprovedBy", fields: [approved_by], references: [user_id])

  // One Leave can expand into multiple TimesheetDay records
  timesheetDays TimesheetDay[]
}

model Hierarchy{
  Hierarchy_id Int @id @default(autoincrement())
  prev_Id Int?
  user_Id Int?         @unique
  next_Id Int[]        @default([]) 
  
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

enum ApprovalStatus {
  Pending
  Approved
  Rejected
}

enum TimesheetStatus {
  Open
  Submitted
}

enum TimesheetDayStatus {
  Pending       // default, waiting for entry
  Filled        // checked in/out & duration provided
  Leave         // Leave applied by employee for that day
  Holiday       // Sat/Sun automatically
  AutoLeave     // Missed entry, auto-marked by system
}

enum LeaveType {
  Sick
  Paid
  Unpaid
  Halfday
  None
}

enum RoleType {
  superAdmin
  subAdmin
  employee
}

enum Gender {
  Male
  Female
  Other
  Prefer_not_to_say
}

enum EmploymentType {
  Full_Time
  Part_Time
  Contract
  Intern
  Consultant
}

enum WorkLocation {
  Office
  Remote
  Hybrid
}

enum EmploymentStatus {
  Active
  Inactive
  Terminated
  On_Leave
  Suspended
}